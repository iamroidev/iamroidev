{
  "rewrites": [
    {
      "source": "/linkedin-og.jpg",
      "destination": "/api/og-image"
    }
  ],
  "headers": [
    {
      "source": "/linkedin-og.jpg",
      "headers": [
        { "key": "Content-Type", "value": "image/jpeg" },
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
